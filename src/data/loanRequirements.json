{
  "universal": {
    "identity": [
      {
        "id": "passport",
        "name": "Passport (Self)",
        "required": true,
        "spec": "Valid passport with minimum 6 months validity",
        "copies": 2,
        "notes": "Self-attested copies"
      },
      {
        "id": "aadhaar",
        "name": "Aadhaar Card",
        "required": true,
        "spec": "Valid Aadhaar card (for Indian students)",
        "copies": 2,
        "alternatives": ["PAN Card", "Voter ID", "Driving License"]
      },
      {
        "id": "pan",
        "name": "PAN Card",
        "required": true,
        "spec": "Permanent Account Number card",
        "copies": 2
      }
    ],
    "academic": [
      {
        "id": "10th_marksheet",
        "name": "10th Marksheet & Certificate",
        "required": true,
        "spec": "Class 10 marksheet and passing certificate",
        "copies": 2
      },
      {
        "id": "12th_marksheet",
        "name": "12th Marksheet & Certificate",
        "required": true,
        "spec": "Class 12 marksheet and passing certificate",
        "copies": 2
      },
      {
        "id": "graduation",
        "name": "Graduation Marksheets & Certificate",
        "required": true,
        "spec": "All semester/year marksheets and final degree certificate",
        "copies": 2
      },
      {
        "id": "gre_gmat",
        "name": "GRE/GMAT Score Card",
        "required": false,
        "spec": "Valid GRE (310+) or GMAT (600+) score",
        "copies": 2,
        "notes": "Required for MS/MBA abroad"
      }
    ],
    "admission": [
      {
        "id": "offer_letter",
        "name": "University Offer Letter",
        "required": true,
        "spec": "Official admission offer from the university",
        "copies": 2,
        "alternatives": ["Confirmation of Admission"]
      },
      {
        "id": "i20",
        "name": "I-20 Form (USA)",
        "required": false,
        "spec": "Certificate of Eligibility for F-1 Student Visa",
        "copies": 2,
        "conditional": "required if studying in USA"
      },
      {
        "id": "cas",
        "name": "CAS Letter (UK)",
        "required": false,
        "spec": "Confirmation of Acceptance for Studies",
        "copies": 2,
        "conditional": "required if studying in UK"
      },
      {
        "id": "coe",
        "name": "CoE (Australia)",
        "required": false,
        "spec": "Confirmation of Enrolment",
        "copies": 2,
        "conditional": "required if studying in Australia"
      },
      {
        "id": "visa",
        "name": "Student Visa",
        "required": false,
        "spec": "Valid student visa for destination country",
        "copies": 2,
        "conditional": "Required before disbursement"
      },
      {
        "id": "fee_structure",
        "name": "Fee Structure from University",
        "required": true,
        "spec": "Detailed breakdown of tuition and living costs",
        "copies": 2
      }
    ],
    "financial": {
      "salaried": [
        {
          "id": "itr_salaried",
          "name": "Income Tax Returns",
          "required": true,
          "spec": "ITR for last 2 years with Acknowledgment",
          "copies": 2
        },
        {
          "id": "form16",
          "name": "Form 16",
          "required": true,
          "spec": "Form 16 from employer for last 2 years",
          "copies": 2
        },
        {
          "id": "salary_slips",
          "name": "Salary Slips",
          "required": true,
          "spec": "Last 3 months salary slips",
          "copies": 2
        },
        {
          "id": "bank_statements",
          "name": "Bank Statements",
          "required": true,
          "spec": "Last 6 months bank statements (Self & Co-applicant)",
          "copies": 2,
          "notes": "Must be certified by bank"
        }
      ],
      "business": [
        {
          "id": "itr_business",
          "name": "Income Tax Returns",
          "required": true,
          "spec": "ITR for last 3 years with Acknowledgment",
          "copies": 2
        },
        {
          "id": "balance_sheet",
          "name": "Balance Sheet",
          "required": true,
          "spec": "Audited Balance Sheet for last 3 years",
          "copies": 2
        },
        {
          "id": "pl_statement",
          "name": "P&L Statement",
          "required": true,
          "spec": "Profit & Loss Statement for last 3 years",
          "copies": 2
        },
        {
          "id": "gst_returns",
          "name": "GST Returns",
          "required": true,
          "spec": "Last 6 months GST return filings",
          "copies": 2
        },
        {
          "id": "bank_statements",
          "name": "Bank Statements",
          "required": true,
          "spec": "Last 12 months bank statements (Business + Personal)",
          "copies": 2
        }
      ]
    },
    "collateral": [
      {
        "id": "property_doc",
        "name": "Property Documents",
        "required": false,
        "spec": "Registered sale agreement, Khata, Encumbrance certificate",
        "copies": 3,
        "conditional": "Required if collateral is property"
      },
      {
        "id": "fd_receipts",
        "name": "FD Receipts",
        "required": false,
        "spec": "Fixed Deposit receipts (pledged)",
        "copies": 2,
        "conditional": "Required if collateral is FD"
      },
      {
        "id": "lic_policy",
        "name": "LIC Policy Documents",
        "required": false,
        "spec": "LIC policy with surrender value certificate",
        "copies": 2,
        "conditional": "Required if collateral is LIC policy"
      }
    ]
  },
